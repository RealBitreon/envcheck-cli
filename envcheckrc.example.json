{
  "description": "envcheck configuration file example",
  "path": ".",
  "envFile": ".env.example",
  "format": "text",
  "failOn": "none",
  "ignore": [
    "node_modules/**",
    "dist/**",
    "build/**",
    ".git/**",
    "**/*.test.js",
    "**/*.spec.js"
  ],
  "noColor": false,
  "quiet": false,
  "watch": false,
  "suggestions": true,
  "progress": true,
  "fix": false
}
