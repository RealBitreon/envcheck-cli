# Application Configuration
# This file contains all environment variables needed for the application

# Database Configuration
DATABASE_URL=postgres://localhost:5432/mydb # PostgreSQL connection string
DB_POOL_SIZE=10 # Maximum number of database connections
DB_TIMEOUT=30000 # Connection timeout in milliseconds

# API Configuration
API_KEY=your_api_key_here # External API key (required)
API_SECRET=your_api_secret # API secret for authentication
API_ENDPOINT=https://api.example.com # Base URL for API requests

# Redis Cache
REDIS_HOST=localhost # Redis server hostname
REDIS_PORT=6379 # Redis server port
REDIS_PASSWORD= # Redis password (leave empty if no auth)

# Application Settings
NODE_ENV=development # Environment: development, staging, production
PORT=3000 # Server port
HOST=0.0.0.0 # Server host
LOG_LEVEL=info # Logging level: debug, info, warn, error

# Security
JWT_SECRET=your_jwt_secret_here # Secret for JWT token signing
SESSION_SECRET=your_session_secret # Secret for session encryption

# Feature Flags
ENABLE_CACHING=true # Enable Redis caching
ENABLE_ANALYTICS=false # Enable analytics tracking
ENABLE_DEBUG=false # Enable debug mode

# AWS Configuration
AWS_REGION=us-east-1 # AWS region
AWS_ACCESS_KEY_ID=your_access_key # AWS access key
AWS_SECRET_ACCESS_KEY=your_secret_key # AWS secret key
AWS_S3_BUCKET=my-bucket # S3 bucket name

# Email Service
SMTP_HOST=smtp.example.com # SMTP server hostname
SMTP_PORT=587 # SMTP server port
SMTP_USER=user@example.com # SMTP username
SMTP_PASSWORD=your_smtp_password # SMTP password
EMAIL_FROM=noreply@example.com # Default from address
