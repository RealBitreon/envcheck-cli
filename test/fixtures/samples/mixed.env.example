# Database
DATABASE_URL=postgres://localhost:5432/mydb # Connection string
DB_POOL_SIZE=10
DB_TIMEOUT=30000 # Timeout in ms

# API
API_KEY=your_api_key_here
API_SECRET=your_api_secret # Secret key
API_ENDPOINT=https://api.example.com

# Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# App
NODE_ENV=development # Environment
PORT=3000
LOG_LEVEL=info
