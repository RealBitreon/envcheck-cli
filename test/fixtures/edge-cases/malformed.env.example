# Valid entries
VALID_VAR=value
ANOTHER_VALID=test # With comment

# Malformed entries (should be skipped)
lowercase_var=value
123_STARTS_WITH_NUMBER=value
MISSING_EQUALS
=NO_VAR_NAME
SPACES IN NAME=value

# Empty and whitespace
   
WHITESPACE_BEFORE=value
WHITESPACE_AFTER=value   

# Special characters
VAR-WITH-DASH=value
VAR.WITH.DOT=value
VAR@SYMBOL=value

# Valid edge cases
_UNDERSCORE_START=value
VAR_123_NUMBERS=value
VERY_LONG_VARIABLE_NAME_THAT_GOES_ON_AND_ON_AND_ON=value

# Multiple equals signs
CONNECTION_STRING=key=value&other=data

# Quoted values
QUOTED="value with spaces"
SINGLE_QUOTED='another value'

# Empty values
EMPTY_VALUE=
EMPTY_WITH_COMMENT= # This is empty

# Unicode and special chars in comments
UNICODE_COMMENT=value # 你好世界 🌍
