# Database Configuration
DATABASE_URL=postgres://localhost:5432/mydb # PostgreSQL connection string
DB_POOL_SIZE=10 # Maximum number of connections

# API Configuration
API_KEY= # External API key (required)
API_SECRET=
API_ENDPOINT=https://api.example.com # API base URL

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD= # Leave empty for no authentication

# Application Settings
NODE_ENV=development # Environment: development, staging, production
PORT=3000
LOG_LEVEL=info # Logging level: debug, info, warn, error

# Feature Flags
ENABLE_CACHING=true
ENABLE_ANALYTICS=false # Toggle analytics tracking

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Email Service
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
